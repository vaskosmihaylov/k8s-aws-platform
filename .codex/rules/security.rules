# Local deterministic policy for the infrastructure pilot.

prefix_rule(pattern = ["make", "bootstrap"], decision = "forbidden", justification = "Creates state infrastructure; human-only", match = ["make bootstrap"])
prefix_rule(pattern = ["make", "apply"], decision = "forbidden", justification = "Applies infrastructure; human-only", match = ["make apply"])
prefix_rule(pattern = ["make", "destroy"], decision = "forbidden", justification = "Destroys infrastructure; human-only", match = ["make destroy"])
prefix_rule(pattern = ["make", "teardown"], decision = "forbidden", justification = "Destroys the platform; human-only", match = ["make teardown"])
prefix_rule(pattern = ["terraform", "apply"], decision = "forbidden", justification = "Applies infrastructure; human-only", match = ["terraform apply tfplan"])
prefix_rule(pattern = ["terraform", "destroy"], decision = "forbidden", justification = "Destroys infrastructure; human-only", match = ["terraform destroy"])
prefix_rule(pattern = ["terraform", "import"], decision = "forbidden", justification = "Mutates Terraform state", match = ["terraform import aws_vpc.main vpc-123"])
prefix_rule(pattern = ["terraform", "state"], decision = "forbidden", justification = "Mutates or exposes Terraform state", match = ["terraform state rm aws_vpc.main"])
prefix_rule(pattern = ["terraform", "force-unlock"], decision = "forbidden", justification = "Unsafe state-lock mutation", match = ["terraform force-unlock LOCK_ID"])

prefix_rule(pattern = ["kubectl", "apply"], decision = "forbidden", justification = "GitOps cluster mutation", match = ["kubectl apply -f app.yaml"])
prefix_rule(pattern = ["kubectl", "delete"], decision = "forbidden", justification = "Cluster deletion", match = ["kubectl delete pod api"])
prefix_rule(pattern = ["kubectl", "drain"], decision = "forbidden", justification = "Node disruption", match = ["kubectl drain node-1"])
prefix_rule(pattern = ["kubectl", "patch"], decision = "forbidden", justification = "Imperative cluster mutation", match = ["kubectl patch deployment api -p '{}'"])
prefix_rule(pattern = ["kubectl", "rollout", "restart"], decision = "forbidden", justification = "Imperative workload restart", match = ["kubectl rollout restart deployment/api"])
prefix_rule(pattern = ["helm", "install"], decision = "forbidden", justification = "Release mutation", match = ["helm install app chart"])
prefix_rule(pattern = ["helm", "upgrade"], decision = "forbidden", justification = "Release mutation", match = ["helm upgrade app chart"])
prefix_rule(pattern = ["helm", "uninstall"], decision = "forbidden", justification = "Release deletion", match = ["helm uninstall app"])
prefix_rule(pattern = ["helm", "rollback"], decision = "forbidden", justification = "Release mutation", match = ["helm rollback app 1"])
prefix_rule(pattern = ["argocd", "app", "sync"], decision = "forbidden", justification = "GitOps reconciliation mutation", match = ["argocd app sync platform"])
prefix_rule(pattern = ["argocd", "app", "rollback"], decision = "forbidden", justification = "GitOps rollback mutation", match = ["argocd app rollback platform 1"])
prefix_rule(pattern = ["argocd", "app", "set"], decision = "forbidden", justification = "GitOps application mutation", match = ["argocd app set platform --revision main"])

prefix_rule(pattern = ["git", "push", "--force"], decision = "forbidden", justification = "Destroys shared history", match = ["git push --force origin main"])
prefix_rule(pattern = ["git", "push", "-f"], decision = "forbidden", justification = "Destroys shared history", match = ["git push -f origin main"])
prefix_rule(pattern = ["git", "commit", "--no-verify"], decision = "forbidden", justification = "Bypasses repository hooks", match = ["git commit --no-verify -m x"])
prefix_rule(pattern = ["git", "add", "-A"], decision = "forbidden", justification = "Bulk staging risks secrets and generated files", match = ["git add -A"])
prefix_rule(pattern = ["git", "add", "--all"], decision = "forbidden", justification = "Bulk staging risks secrets and generated files", match = ["git add --all"])
prefix_rule(pattern = ["git", "add", "."], decision = "forbidden", justification = "Bulk staging risks secrets and generated files", match = ["git add ."])
prefix_rule(pattern = ["rm", "-rf"], decision = "forbidden", justification = "Destructive filesystem operation", match = ["rm -rf tmp"])

prefix_rule(pattern = ["terraform", "init"], decision = "prompt", justification = "Downloads providers and may access backend", match = ["terraform init"])
prefix_rule(pattern = ["terraform", "plan"], decision = "prompt", justification = "Requires verified account, region, workspace, and backend", match = ["terraform plan -out=tfplan"])
prefix_rule(pattern = ["make", "plan"], decision = "prompt", justification = "Runs a cloud-backed Terraform plan", match = ["make plan"])
prefix_rule(pattern = ["aws", "eks", "update-kubeconfig"], decision = "prompt", justification = "Writes local cluster credentials", match = ["aws eks update-kubeconfig --name cluster"])
prefix_rule(pattern = ["make", "kubeconfig"], decision = "prompt", justification = "Writes local cluster credentials", match = ["make kubeconfig"])
prefix_rule(pattern = ["git", "commit"], decision = "prompt", justification = "VCS mutation", match = ["git commit -m x"])
prefix_rule(pattern = ["git", "push"], decision = "prompt", justification = "Publishes changes and may trigger deployment", match = ["git push origin feature"])
prefix_rule(pattern = ["gh", "issue", "create"], decision = "prompt", justification = "Creates an external issue", match = ["gh issue create --title x"])
prefix_rule(pattern = ["gh", "issue", "comment"], decision = "prompt", justification = "Publishes an external comment", match = ["gh issue comment 1 --body x"])
prefix_rule(pattern = ["gh", "pr", "create"], decision = "prompt", justification = "Creates an external pull request", match = ["gh pr create --title x"])
prefix_rule(pattern = ["gh", "pr", "merge"], decision = "prompt", justification = "Merges and may trigger deployment", match = ["gh pr merge 1"])

prefix_rule(pattern = ["terraform", "fmt", "-check"], decision = "allow", justification = "Read-only format check", match = ["terraform fmt -check -recursive terraform/"])
prefix_rule(pattern = ["terraform", "validate"], decision = "allow", justification = "Static Terraform validation", match = ["terraform validate"])
prefix_rule(pattern = ["kustomize", "build"], decision = "allow", justification = "Local manifest rendering", match = ["kustomize build apps/demo-api/base"])
prefix_rule(pattern = ["kubectl", "kustomize"], decision = "allow", justification = "Local manifest rendering without cluster access", match = ["kubectl kustomize apps/demo-api/base"])
prefix_rule(pattern = ["git", "status"], decision = "allow", justification = "Read-only VCS", match = ["git status"])
prefix_rule(pattern = ["git", "diff"], decision = "allow", justification = "Read-only VCS", match = ["git diff"])
prefix_rule(pattern = ["git", "log"], decision = "allow", justification = "Read-only VCS", match = ["git log -n 5"])
prefix_rule(pattern = ["git", "show"], decision = "allow", justification = "Read-only VCS", match = ["git show HEAD"])
